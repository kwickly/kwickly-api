{
  "name": "kwickly-api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --target bun --outfile dist/index.js",
    "start": "bun run dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:local:migrate": "DB_TARGET=local bun run db:migrate",
    "db:prod:migrate": "DB_TARGET=prod bun run db:migrate",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pino": "^7.0.5",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@neondatabase/serverless": "^1.1.0",
    "@trigger.dev/sdk": "^4.4.6",
    "@upstash/redis": "^1.38.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.6.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.9"
  }
}
