{
  "name": "kwickly-api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --target bun --outfile dist/index.js",
    "start": "bun run dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "db:seed:punjabi": "bun run src/db/seed-punjabi-chaska.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:local:migrate": "DB_TARGET=local bun run db:migrate",
    "db:prod:migrate": "DB_TARGET=prod bun run db:migrate",
    "test": "bun test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pino": "^7.0.5",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/stream": "^1.1.0",
    "@elysiajs/swagger": "^1.3.1",
    "@neondatabase/serverless": "^1.1.0",
    "@trigger.dev/sdk": "^4.4.6",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.6.2",
    "firebase-admin": "^14.1.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.9"
  }
}
