# ─── Database ──────────────────────────────────────────────────────────────────
# NeonDB HTTP (serverless) — used by Drizzle ORM
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/kwickly?sslmode=require

# NeonDB Pooled TCP — used by Bun.sql for raw/analytics queries
DATABASE_POOLED_URL=postgresql://user:pass@ep-xxx-pooler.neon.tech/kwickly?pgbouncer=true&sslmode=require

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_EXPIRY=15m
REFRESH_EXPIRY=7d

# ─── Redis / Rate Limiting (Upstash) ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ─── Payments (Razorpay) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# ─── File Storage (Cloudflare R2) ──────────────────────────────────────────────
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=kwickly-media
R2_PUBLIC_URL=https://media.kwickly.com

# ─── Push Notifications (OneSignal) ────────────────────────────────────────────
ONESIGNAL_APP_ID=xxx
ONESIGNAL_REST_API_KEY=xxx

# ─── WhatsApp (WATI) ───────────────────────────────────────────────────────────
WATI_API_URL=https://live-server.wati.io
WATI_API_KEY=xxx

# ─── OTP (MSG91) ───────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=xxx
MSG91_TEMPLATE_ID=xxx

# ─── Background Jobs (Trigger.dev) ─────────────────────────────────────────────
TRIGGER_SECRET_KEY=xxx

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx

# ─── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
